#!@TERMUX_PREFIX@/bin/sh
set -e -u

SCRIPTNAME=termux-notification-list
show_usage () {
    echo "Usage: $SCRIPTNAME"
    echo "Default: Show the list of currently shown notifications."
    echo "m: Show the list of current medias."
	echo "a: Start listening to notifications."
	echo "o: Stop listening to notifications."
    exit 0
}

argument=false
while getopts :hmao option
do
    case "$option" in
        h) show_usage;;
        m) argument=media;;
		a) argument=start-listen;;
		o) argument=stop-listen;;
        ?) echo "$SCRIPTNAME: illegal option -$OPTARG"; exit 1;
    esac
done
shift $((OPTIND-1))

if [ $# != 0 ]; then echo "$SCRIPTNAME: too many arguments"; exit 1; fi

TERMUX_API=@TERMUX_PREFIX@/libexec/termux-api
if [ $argument = false ]
then
	$TERMUX_API NotificationList
else
	$TERMUX_API NotificationList --esn $argument
fi
